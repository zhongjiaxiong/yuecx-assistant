.booking-card {
  background: #fff;
  border-radius: 16rpx;
  margin: 12rpx 0;
  overflow: hidden;
  box-shadow: 0 2rpx 12rpx rgba(0, 0, 0, 0.06);
  border: 2rpx solid #1677ff;
}

.card-title {
  display: flex;
  align-items: center;
  gap: 8rpx;
  padding: 20rpx 24rpx;
  font-size: 30rpx;
  font-weight: 600;
  color: #1677ff;
  background: #f0f5ff;
  border-bottom: 1rpx solid #e6f0ff;
}

.title-icon {
  font-size: 32rpx;
}

.info-grid {
  padding: 20rpx 24rpx;
}

.info-item {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 12rpx 0;
  border-bottom: 1rpx solid #f5f5f5;
}

.info-item:last-child {
  border-bottom: none;
}

.info-label {
  font-size: 26rpx;
  color: #999;
  flex-shrink: 0;
  width: 140rpx;
}

.info-value {
  font-size: 28rpx;
  color: #333;
  text-align: right;
  flex: 1;
}

.info-value.highlight {
  color: #1677ff;
  font-weight: 500;
}

.info-value.price {
  color: #ff4d4f;
  font-weight: 600;
  font-size: 32rpx;
}

.action-area {
  padding: 20rpx 24rpx 24rpx;
}

.buy-btn {
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  color: #fff;
  text-align: center;
  padding: 24rpx 0;
  border-radius: 12rpx;
  font-size: 32rpx;
  font-weight: 600;
  letter-spacing: 2rpx;
}
