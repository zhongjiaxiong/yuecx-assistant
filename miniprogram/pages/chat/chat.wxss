.chat-container {
  display: flex;
  flex-direction: column;
  height: 100vh;
  background: #f5f5f5;
}

/* 定位提示栏 */
.location-bar {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 16rpx 24rpx;
  background: #fffbe6;
  border-bottom: 1rpx solid #ffe58f;
  flex-shrink: 0;
}

.location-text {
  font-size: 24rpx;
  color: #ad8b00;
}

.location-btn {
  font-size: 24rpx;
  color: #1677ff;
  padding: 6rpx 20rpx;
  border: 1rpx solid #1677ff;
  border-radius: 20rpx;
}

/* 消息列表 */
.message-list {
  flex: 1;
  padding: 20rpx 24rpx;
  overflow-y: auto;
}

.message {
  display: flex;
  margin-bottom: 24rpx;
  align-items: flex-start;
}

.message.user {
  justify-content: flex-end;
}

.avatar {
  width: 64rpx;
  height: 64rpx;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
  font-weight: 600;
  flex-shrink: 0;
}

.assistant-avatar {
  background: linear-gradient(135deg, #1677ff, #4096ff);
  color: #fff;
  margin-right: 16rpx;
}

.user-avatar {
  background: #e6e6e6;
  color: #666;
  margin-left: 16rpx;
}

.bubble-wrap {
  max-width: 80%;
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.bubble {
  background: #fff;
  padding: 20rpx 24rpx;
  border-radius: 16rpx;
  font-size: 28rpx;
  line-height: 1.6;
  word-break: break-all;
  box-shadow: 0 1rpx 4rpx rgba(0, 0, 0, 0.04);
  max-width: 80%;
}

.message.user .bubble,
.user-bubble {
  background: #1677ff;
  color: #fff;
  max-width: none;
}

.message.assistant .bubble {
  max-width: none;
}

/* loading */
.loading-bubble {
  display: flex;
  align-items: center;
  gap: 16rpx;
  padding: 20rpx 28rpx;
}

.loading-dots {
  display: flex;
  gap: 8rpx;
}

.dot {
  width: 12rpx;
  height: 12rpx;
  border-radius: 50%;
  background: #1677ff;
  animation: dotBounce 1.4s infinite ease-in-out both;
}

.dot:nth-child(1) { animation-delay: -0.32s; }
.dot:nth-child(2) { animation-delay: -0.16s; }
.dot:nth-child(3) { animation-delay: 0s; }

@keyframes dotBounce {
  0%, 80%, 100% { opacity: 0.3; transform: scale(0.8); }
  40% { opacity: 1; transform: scale(1); }
}

.loading-text {
  font-size: 24rpx;
  color: #999;
}

/* 输入区 */
.input-area {
  display: flex;
  align-items: center;
  padding: 16rpx 24rpx;
  padding-bottom: calc(16rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-top: 1rpx solid #e8e8e8;
  flex-shrink: 0;
}

.chat-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 36rpx;
  padding: 0 28rpx;
  font-size: 28rpx;
}

.send-btn {
  margin-left: 16rpx;
  padding: 14rpx 28rpx;
  border-radius: 36rpx;
  font-size: 28rpx;
  background: #e8e8e8;
  color: #999;
  flex-shrink: 0;
}

.send-btn.active {
  background: #1677ff;
  color: #fff;
}
