.profile-container {
  padding: 24rpx;
  min-height: 100vh;
  background: #f5f5f5;
}

/* 用户卡片 */
.user-card {
  display: flex;
  align-items: center;
  background: linear-gradient(135deg, #1677ff 0%, #4096ff 100%);
  border-radius: 20rpx;
  padding: 40rpx 32rpx;
  margin-bottom: 24rpx;
}

.user-avatar {
  width: 96rpx;
  height: 96rpx;
  border-radius: 50%;
  background: rgba(255, 255, 255, 0.25);
  display: flex;
  align-items: center;
  justify-content: center;
  margin-right: 24rpx;
  flex-shrink: 0;
}

.avatar-text {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.user-info {
  display: flex;
  flex-direction: column;
}

.user-phone {
  font-size: 36rpx;
  color: #fff;
  font-weight: 600;
}

.user-name {
  font-size: 32rpx;
  color: #fff;
  font-weight: 500;
}

.user-label {
  font-size: 24rpx;
  color: rgba(255, 255, 255, 0.75);
  margin-top: 4rpx;
}

/* 通用 section */
.section {
  margin-bottom: 24rpx;
}

/* 手机号登录 */
.phone-btn {
  background: #1677ff;
  color: #fff;
  border: none;
  border-radius: 12rpx;
  font-size: 30rpx;
  padding: 24rpx 0;
  font-weight: 500;
}

.phone-btn::after {
  border: none;
}

.phone-hint {
  display: block;
  text-align: center;
  font-size: 22rpx;
  color: #999;
  margin-top: 12rpx;
}

/* 菜单列表 */
.menu-section {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
}

.menu-item {
  display: flex;
  align-items: center;
  padding: 28rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
}

.menu-item:last-child {
  border-bottom: none;
}

.menu-icon {
  font-size: 36rpx;
  margin-right: 16rpx;
}

.menu-text {
  flex: 1;
  font-size: 28rpx;
  color: #333;
}

.menu-arrow {
  font-size: 32rpx;
  color: #ccc;
}

/* 关于 */
.about-section {
  background: #fff;
  border-radius: 16rpx;
  padding: 24rpx;
}

.about-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 8rpx 0;
}

.about-label {
  font-size: 26rpx;
  color: #999;
}

.about-value {
  font-size: 26rpx;
  color: #666;
}

.about-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 8rpx;
}

/* 退出登录 */
.logout-btn {
  text-align: center;
  padding: 24rpx 0;
  background: #fff;
  border-radius: 12rpx;
  font-size: 28rpx;
  color: #ff4d4f;
}
