# 粤程助手环境变量配置

# ===============================
# LLM 配置 (通义千问)
# ===============================
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_API_KEY=your-dashscope-api-key
LLM_MODEL=qwen-max

# ===============================
# 数据库配置 (PostgreSQL/Supabase)
# ===============================
DATABASE_URL=postgresql://user:password@host:port/database

# ===============================
# Stripe 支付配置
# ===============================
# Stripe Secret Key (测试环境使用 sk_test_xxx, 生产环境使用 sk_live_xxx)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key

# Stripe Webhook Secret (用于验证 webhook 签名)
# 在 Stripe Dashboard 中配置 webhook endpoint 后获取
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# 服务器公网地址 (用于构建回调 URL)
# 开发环境: http://localhost:3000
# 生产环境: https://your-domain.com
HOST_URL=http://localhost:3000

# ===============================
# 粤出行 API 配置
# ===============================
YUECX_HOST=https://15676888-api.ylxweb.com
YUECX_CORP_ID=ycx
YUECX_APPID=wx44d254291f27af7c

# ===============================
# 车盈网 API 配置
# ===============================
BUSBOSS_HOST=https://wx.open.class.busboss.cn
BUSBOSS_TOKEN=your-busboss-token
